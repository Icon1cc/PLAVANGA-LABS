# Copy to .env.local for local dev, and set the same values in the Vercel
# project (Settings > Environment Variables) for the deployed site.

# Public site URL. Used for metadataBase, Open Graph, and canonical links.
# Set this to your real deployed URL, e.g. https://plavanga-labs.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Where contact enquiries are delivered. Any inbox is fine ONCE a sender
# domain is verified (see CONTACT_FROM_EMAIL).
CONTACT_TO_EMAIL=hello@your-domain.com

# The sender address. Resend only sends from a domain you have verified at
# https://resend.com/domains. A free mailbox such as @gmail.com cannot be
# verified and is rejected with a 403. Without a verified domain the only
# working sender is onboarding@resend.dev, and it can deliver only to the email
# on your Resend account. Verify a domain to send from your brand to any inbox.
CONTACT_FROM_EMAIL=Plavanga Labs <website@your-domain.com>
