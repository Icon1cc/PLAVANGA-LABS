# Copy to .env.local for local dev, and set the same values in the Vercel
# project (Settings > Environment Variables) for the deployed site.

# Public site URL. Used for metadataBase, Open Graph, and canonical links.
NEXT_PUBLIC_SITE_URL=https://www.plavangalabs.com

# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Where contact enquiries are delivered. Any inbox is fine ONCE a sender
# domain is verified (see CONTACT_FROM_EMAIL).
CONTACT_TO_EMAIL=suman@plavangalabs.com

# The sender address. Resend only sends from a domain verified at
# https://resend.com/domains. It does not have to be a real mailbox, and it is
# not the same thing as having Google Workspace on the domain: Workspace
# handles inbound mail, Resend needs its own DKIM and SPF records before it
# will send anything. A free mailbox such as @gmail.com cannot be verified and
# is rejected with a 403. Until the domain verifies, the only sender Resend
# accepts is onboarding@resend.dev, and it can deliver only to the email on
# your Resend account.
CONTACT_FROM_EMAIL=Plavanga Labs <website@plavangalabs.com>
